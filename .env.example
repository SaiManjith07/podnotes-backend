# Whisper
# WHISPER_MODEL_SIZE=base

# Optional: path to Netscape cookies.txt while logged into YouTube (helps when YouTube returns HTTP 429).
# YOUTUBE_COOKIES_FILE=C:\path\to\cookies.txt

# Google Gemini (LangChain note generation) — use an API key from https://aistudio.google.com/apikey
# Either variable works:
# GEMINI_API_KEY=your_key_here
# GOOGLE_API_KEY=your_key_here
# Optional model override (must be available to your key):
# GEMINI_MODEL=gemini-2.5-flash

# Optional: trim transcript sent to the model
# NOTES_TRANSCRIPT_MAX_CHARS=24000

# Note chat tuning
# Brief/default chat (smaller context + shorter answers)
# NOTE_CHAT_TRANSCRIPT_MAX_CHARS_BRIEF=6000
# NOTE_CHAT_MAX_OUTPUT_TOKENS_BRIEF=700
# Expanded chat when user asks "more details"/"full transcript"
# NOTE_CHAT_TRANSCRIPT_MAX_CHARS=28000
# NOTE_CHAT_MAX_OUTPUT_TOKENS_EXPANDED=1400

# CORS (comma-separated). Defaults include localhost and 127.0.0.1 on port 8000.
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: server-side Firestore sync for POST /api/podcast/from-youtube (same paths as the web client).
# Download a service account JSON from Firebase Console → Project settings → Service accounts.
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\serviceAccount.json
# Or set GOOGLE_APPLICATION_CREDENTIALS to that path.
# For hosted backends, you can paste the raw JSON (single line) instead:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
